# Shalvinat HMS — Production Environment Variables
# Copy this to .env and fill in real values before deployment

NODE_ENV=production
PORT=4000

# MongoDB Atlas connection string (create free cluster at https://cloud.mongodb.com)
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/shalvinat_hms?retryWrites=true&w=majority

# JWT secrets — generate strong random strings (use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_ACCESS_SECRET=change-me-to-64-char-random-string
JWT_REFRESH_SECRET=change-me-to-64-char-random-string

# AES-256-GCM key for clinical data encryption — 32 bytes hex
FIELD_ENCRYPTION_KEY=change-me-to-64-char-random-string

# Token expiry
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=8h

# Bcrypt rounds (10-15, higher = more secure but slower)
BCRYPT_ROUNDS=12

# Allowed frontend origins (comma-separated for multiple domains)
CLIENT_ORIGIN=https://your-domain.com,https://www.your-domain.com
